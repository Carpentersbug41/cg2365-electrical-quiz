        "title": "Magnification example",
        "given": "Image size = 20 mm, actual size = 0.02 mm",
        "steps": [
          { "stepNumber": 1, "description": "Use magnification formula.", "formula": "magnification = image / actual" },
          { "stepNumber": 2, "description": "Substitute values.", "calculation": "20 / 0.02" },
          { "stepNumber": 3, "description": "Compute answer.", "result": "1000" }
        ]
      }
