{
  "id": "BIO-103-1B",
  "title": "Variation and Inheritance",
  "description": "Use genetic vocabulary to explain inherited and environmental variation.",
  "layout": "linear-flow",
  "unit": "Unit BIO-103",
  "topic": "Genetics Foundations",
  "learningOutcomes": [
    "Define variation, inherited characteristics, and environmental characteristics.",
    "Explain how inheritance contributes to variation.",
    "Classify examples of variation."
  ],
  "prerequisites": ["BIO-103-1A"],
  "blocks": [
    {
      "id": "BIO-103-1B-outcomes",
      "type": "outcomes",
      "order": 1,
      "content": {
        "outcomes": [
          { "text": "Define variation and inheritance.", "bloomLevel": "remember" },
          { "text": "Classify causes of variation.", "bloomLevel": "apply" }
        ]
      }
    },
    {
      "id": "BIO-103-1B-explain",
      "type": "explanation",
      "order": 2,
      "content": {
        "title": "Two sources of variation",
        "content": "Variation in a population comes from inherited genetic differences and environmental factors. Many characteristics are influenced by both."
      }
    },
    {
      "id": "BIO-103-1B-guided",
      "type": "guided-practice",
      "order": 3,
      "content": {
        "title": "Classify examples",
        "problem": "Identify likely causes of variation.",
        "steps": [
          {
            "stepNumber": 1,
            "prompt": "Eye color is mainly inherited or environmental?",
            "expectedAnswer": ["inherited", "genetic"],
            "hint": "Think about traits passed from parents."
          },
          {
            "stepNumber": 2,
            "prompt": "Language spoken is mainly inherited or environmental?",
            "expectedAnswer": ["environmental", "environment"],
            "hint": "Consider where and how a person is raised."
          }
        ]
      }
    },
    {
      "id": "BIO-103-1B-practice",
      "type": "practice",
      "order": 4,
      "content": {
        "title": "Practice",
        "questions": [
          {
            "id": "BIO-103-1B-Q1",
            "questionText": "What does variation mean in biology?",
            "expectedAnswer": ["differences between individuals", "differences in characteristics between organisms"],
            "answerType": "short-text"
          },
          {
            "id": "BIO-103-1B-Q2",
            "questionText": "Name one characteristic strongly affected by environment.",
            "expectedAnswer": ["accent", "language", "scars", "sun tan", "diet-related mass"],
            "answerType": "short-text"
          }
        ]
      }
    },
    {
      "id": "BIO-103-1B-review",
      "type": "spaced-review",
      "order": 5,
      "content": {
        "title": "Review",
        "questions": [
          {
            "id": "BIO-103-1B-R1",
            "questionText": "Give one inherited and one environmental example of variation.",
            "expectedAnswer": ["eye colour and language", "blood group and accent", "inherited eye colour and environmental tan"]
          }
        ]
      }
    }
  ],
