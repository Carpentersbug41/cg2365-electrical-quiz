        "terms": [
          { "term": "Nucleus", "definition": "Contains DNA and controls cell activity." },
          { "term": "Cell membrane", "definition": "Controls what enters and leaves the cell." },
          { "term": "Mitochondria", "definition": "Site of aerobic respiration." },
          { "term": "Chloroplast", "definition": "Site of photosynthesis in plant cells." }
        ]
      }
    },
    {
      "id": "BIO-101-1A-explain",
      "type": "explanation",
      "order": 3,
      "content": {
        "title": "Animal vs Plant Cells",
        "content": "Animal and plant cells are both eukaryotic. Plant cells have extra structures: a cellulose cell wall, chloroplasts, and a large permanent vacuole."
      }
    },
