        "outcomes": [
          { "text": "Define core genetics terms.", "bloomLevel": "remember" },
          { "text": "Explain how genes influence characteristics.", "bloomLevel": "understand" }
        ]
      }
    },
    {
      "id": "BIO-103-1A-vocab",
      "type": "vocab",
      "order": 2,
      "content": {
        "terms": [
          { "term": "DNA", "definition": "A molecule that carries genetic information." },
          { "term": "Gene", "definition": "A section of DNA that codes for a protein." },
          { "term": "Chromosome", "definition": "A long DNA molecule containing many genes." },
          { "term": "Genome", "definition": "The complete set of genetic material in an organism." }
        ]
      }
    },
    {
      "id": "BIO-103-1A-explain",
      "type": "explanation",
      "order": 3,
      "content": {
        "title": "From DNA to characteristics",
        "content": "Genes are instructions for making proteins. Proteins can affect cell structure and chemical reactions, which contributes to observable characteristics."
      }
    },
    {
      "id": "BIO-103-1A-practice",
      "type": "practice",
