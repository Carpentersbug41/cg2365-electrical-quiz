            "questionText": "What is a gene?",
            "expectedAnswer": ["a section of dna that codes for a protein", "part of dna that carries instructions for proteins"],
            "answerType": "short-text"
          },
          {
            "id": "BIO-103-1A-Q2",
            "questionText": "Where are genes found?",
            "expectedAnswer": ["on chromosomes", "in dna on chromosomes"],
            "answerType": "short-text"
          }
        ]
      }
    },
